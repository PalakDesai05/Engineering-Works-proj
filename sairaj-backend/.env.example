# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# Path to the SQLite database file (auto-created on first run)
DB_PATH=./sairaj.db

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Face Recognition Service ─────────────────────────────────────────────────
FACE_SERVICE_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Company Info (used in PDF generation) ────────────────────────────────────
COMPANY_NAME=Sairaj Engineering Works
COMPANY_ADDRESS=Industrial Area, Aurangabad, Maharashtra - 431001
COMPANY_PHONE=+91-XXXXXXXXXX
COMPANY_EMAIL=info@sairajengineering.com
COMPANY_GST=27ABCDE1234F1Z5
